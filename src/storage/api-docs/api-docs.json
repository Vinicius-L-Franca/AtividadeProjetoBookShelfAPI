                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "genre_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "title": {
                                        "type": "string",
                                        "example": "Clean Code",
                                        "maxLength": 255
                                    },
                                    "author": {
                                        "type": "string",
                                        "example": "Robert C. Martin",
                                        "maxLength": 255
                                    },
                                    "pages": {
                                        "type": "integer",
                                        "example": 464,
                                        "nullable": true
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "finished",
                                        "enum": [
                                            "to_read",
                                            "reading",
                                            "finished"
                                        ]
                                    },
                                    "rating": {
                                        "type": "integer",
                                        "example": 5,
                                        "nullable": true,
                                        "maximum": 5,
                                        "minimum": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Livro atualizado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Book"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Livro não encontrado"
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                }
            }
        },
