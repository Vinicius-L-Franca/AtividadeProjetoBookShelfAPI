{
    "openapi": "3.0.0",
    "info": {
        "title": "BookShelf API",
        "description": "API REST para gerenciar uma estante de livros por gêneros.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8000",
            "description": "Servidor local"
        }
    ],
    "paths": {
        "/api/books": {
            "get": {
                "tags": [
                    "Livros"
                ],
                "summary": "Listar livros",
                "description": "Retorna todos os livros cadastrados. Inclui o gênero relacionado (campo 'genre').",
                "operationId": "9017a3fa89d6636329067c858b27a6fa",
                "responses": {
                    "200": {
                        "description": "Lista de livros",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Book"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Livros"
                ],
                "summary": "Criar livro",
                "description": "Cria um novo livro.",
                "operationId": "72f82e1cd6f08112323f87053277ca99",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "genre_id",
                                    "title",
                                    "author",
                                    "status"
                                ],
                                "properties": {
                                    "genre_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "title": {
                                        "type": "string",
                                        "example": "Clean Code",
                                        "maxLength": 255
                                    },
                                    "author": {
                                        "type": "string",
                                        "example": "Robert C. Martin",
                                        "maxLength": 255
                                    },
                                    "pages": {
                                        "type": "integer",
                                        "example": 464,
                                        "nullable": true
                                    },
                                    "status": {
                                        "type": "string",
                                        "example": "reading",
                                        "enum": [
                                            "to_read",
                                            "reading",
                                            "finished"
                                        ]
                                    },
                                    "rating": {
                                        "type": "integer",
                                        "example": 5,
                                        "nullable": true,
                                        "maximum": 5,
                                        "minimum": 1
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Livro criado",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Book"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Erro de validação"
                    }
                }
            }
        },
