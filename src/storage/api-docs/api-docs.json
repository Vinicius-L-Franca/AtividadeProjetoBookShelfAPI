    "components": {
        "schemas": {
            "Book": {
                "required": [
                    "id",
                    "genre_id",
                    "title",
                    "author",
                    "status",
                    "created_at",
                    "updated_at"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "genre_id": {
                        "type": "integer",
                        "example": 1
                    },
                    "title": {
                        "type": "string",
                        "example": "1984"
                    },
                    "author": {
                        "type": "string",
                        "example": "George Orwell"
                    },
                    "pages": {
                        "type": "integer",
                        "example": 328,
                        "nullable": true
                    },
                    "status": {
                        "type": "string",
                        "example": "to_read",
                        "enum": [
                            "to_read",
                            "reading",
                            "finished"
                        ]
                    },
                    "rating": {
                        "type": "integer",
                        "example": 5,
                        "nullable": true,
                        "maximum": 5,
                        "minimum": 1
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-07T14:09:44.000000Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-07T14:09:44.000000Z"
                    },
                    "genre": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/Genre"
                            }
                        ],
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "Genre": {
                "required": [
                    "id",
                    "name",
                    "created_at",
                    "updated_at"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "Ficção"
                    },
                    "description": {
                        "type": "string",
                        "example": "Romances e histórias fictícias",
                        "nullable": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-07T14:09:44.000000Z"
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "example": "2026-04-07T14:09:44.000000Z"
                    }
                },
                "type": "object"
