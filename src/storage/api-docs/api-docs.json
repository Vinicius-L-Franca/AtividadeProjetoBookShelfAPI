            "delete": {
                "tags": [
                    "Livros"
                ],
                "summary": "Excluir livro",
                "description": "Exclui um livro pelo ID.",
                "operationId": "eda12c526d0ccacaecea5f3d8f15d6df",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "description": "ID do livro",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Livro excluído"
                    },
                    "404": {
                        "description": "Livro não encontrado"
